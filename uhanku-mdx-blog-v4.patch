+  --blog-border: color-mix(in srgb, var(--blog-text) 16%, transparent);
+  --blog-accent: #66d9c7;
+
+  min-height: 100vh;
+  background: var(--blog-bg);
+  color: var(--blog-text);
+}
+
+.blog-header {
+  position: sticky;
+  top: 0;
+  z-index: 10;
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  width: min(1120px, calc(100% - 40px));
+  margin: 0 auto;
+  padding: 20px 0;
+  border-bottom: 1px solid var(--blog-border);
+  background: color-mix(in srgb, var(--blog-bg) 88%, transparent);
+  backdrop-filter: blur(14px);
+}
+
+.blog-header nav {
+  display: flex;
+  gap: 20px;
+}
+
+.blog-header a,
+.blog-card a,
+.blog-back-link,
+.blog-not-found a {
+  color: inherit;
+  text-decoration: none;
+}
+
+.blog-header a:hover,
+.blog-card a:hover,
+.blog-back-link:hover,
+.blog-not-found a:hover {
+  color: var(--blog-accent);
